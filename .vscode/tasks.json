{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "uv: run active file",
            "type": "shell",
            "command": "uv",
            "args": [
                "run",
                "${fileBasename}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}